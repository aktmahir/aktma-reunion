@model SchoolSocialApp.Models.ClassSetting

@{
    ViewData["Title"] = "Class Settings";
}

<h2>Class Settings</h2>

<form asp-action="Settings" method="post">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ClassId" />

    <div class="mb-3 form-check">
        <input asp-for="IsPostingAllowed" class="form-check-input" />
        <label asp-for="IsPostingAllowed" class="form-check-label">Allow posting in this class</label>
    </div>

    <div class="mb-3 form-check">
        <input asp-for="CanShareResources" class="form-check-input" />
        <label asp-for="CanShareResources" class="form-check-label">Allow resource sharing</label>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Save Settings</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
